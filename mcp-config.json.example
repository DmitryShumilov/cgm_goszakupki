{
  "mcpServers": {
    "postgresql": {
      "command": "npx",
      "args": [
        "@ahmedmustahid/postgres-mcp-server",
        "stdio"
      ],
      "env": {
        "POSTGRES_USERNAME": "postgres",
        "POSTGRES_PASSWORD": "your_password_here",
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "5432",
        "POSTGRES_DATABASE": "cgm_dashboard"
      }
    }
  }
}
